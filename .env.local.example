# Database Configuration
# Uncomment and configure based on your database choice

# MongoDB
# MONGODB_URI=mongodb://localhost:27017/reminder-app
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/reminder-app

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/reminder-app

# NextAuth Configuration (for future authentication)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here

# API Keys (for future LLM/RAG integration)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Vector Database (for future RAG implementation)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-environment
# PINECONE_INDEX=reminder-app
