# ===========================================
# FYP Reminder App - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in Project Settings > Environment Variables

# -------------------------------------------
# MongoDB (Required)
# -------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/reminder-app
MONGODB_DB=reminder-app

# -------------------------------------------
# Auth.js v5 (Required)
# -------------------------------------------
# For local development:
AUTH_URL=http://localhost:3000
# For Vercel: Set to your production URL (e.g., https://your-app.vercel.app)
# Vercel automatically sets AUTH_URL for you in production

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here

# -------------------------------------------
# LLM API (Required for AI features)
# -------------------------------------------
# OpenRouter API (recommended)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=x-ai/grok-4.1-fast

# Or use OpenAI directly:
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4o

# -------------------------------------------
# Perplexity API (Required for searchWeb tool)
# -------------------------------------------
PERPLEXITY_API_KEY=your-perplexity-api-key

# -------------------------------------------
# Optional: Vector Database (for future RAG)
# -------------------------------------------
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-environment
# PINECONE_INDEX=reminder-app
