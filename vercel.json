{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/ai/**/*.js": {
      "maxDuration": 60
    },
    "app/api/reminders/**/*.js": {
      "maxDuration": 30
    },
    "app/api/cron/**/*.js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/unsnooze",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/notify",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-subscriptions",
      "schedule": "0 0 * * *"
    }
  ]
}
